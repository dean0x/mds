---
fruits:
  - banana
  - apple
  - cherry
  - apple
  - banana
numbers:
  - 3
  - 1
  - 4
  - 1
  - 5
csv: "red,green,blue"
---

SPLIT: {split(csv, ",")}
JOIN: {join(fruits, " | ")}
LENGTH string: {length(csv)}
LENGTH array: {length(fruits)}
FIRST: {first(fruits)}
LAST: {last(fruits)}
REVERSE: {reverse(fruits)}
SORT strings: {sort(fruits)}
SORT numbers: {sort(numbers)}
UNIQUE: {unique(fruits)}
CONTAINS array true: {contains(fruits, "cherry")}
CONTAINS array false: {contains(fruits, "grape")}
SLICE array: {slice(fruits, 1, 3)}
